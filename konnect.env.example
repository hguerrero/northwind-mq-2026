# Copy to konnect.env and fill values before running docker compose
# See demo script "Environment Bootstrap" section for step-by-step instructions.

# ── Konnect connection ────────────────────────────────────────────────────────
KONG_KONNECT_REGION=<your-region>        # e.g. us, eu, au
KONG_KONNECT_DOMAIN=konghq.com

# Gateway cluster ID — obtained after applying kongctl/data_plane_certificate.yaml
# kongctl get event-gateway northwind-event-gateway --output json --jq '.id' --jq-raw-output
KONG_KONNECT_GATEWAY_CLUSTER_ID=<your-cluster-id>

# ── Data plane TLS identity ───────────────────────────────────────────────────
# Generate with:
#   openssl req -new -x509 -nodes -newkey rsa:2048 \
#     -subj "/CN=event-gateway/C=US" \
#     -keyout kongctl/certs/key.crt \
#     -out    kongctl/certs/tls.crt
#
# Then load into this file with:
#   printf 'KONG_KONNECT_CLIENT_CERT="%s"\n' "$(cat kongctl/certs/tls.crt)" >> konnect.env
#   printf 'KONG_KONNECT_CLIENT_KEY="%s"\n'  "$(cat kongctl/certs/key.crt)"  >> konnect.env
KONG_KONNECT_CLIENT_CERT="<paste tls.crt PEM content here>"
KONG_KONNECT_CLIENT_KEY="<paste key.crt PEM content here>"

# ── Optional ─────────────────────────────────────────────────────────────────
# KAFKA_USERNAME=
# KAFKA_PASSWORD=
# TRANSACTION_ENCRYPTION_KEY=   # Required for Scene 6 (wire transfer encryption)
#   export TRANSACTION_ENCRYPTION_KEY=$(openssl rand -base64 32)
